# ============================================
# NoteApp - Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database ---
DB_USER=noteapp
DB_PASSWORD=your_strong_password_here
DB_NAME=noteapp

# --- JWT ---
JWT_SECRET=your_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# --- Email (SMTP) ---
# Gmail example: smtp.gmail.com / port 587
# Use App Password if 2FA enabled
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=NoteApp <your_email@gmail.com>

# --- App ---
APP_URL=http://localhost
NODE_ENV=production
